{
  "name": "antenna-monitor",
  "version": "1.0.0",
  "description": "Antenna Monitor Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac"
  },
  "build": {
    "appId": "com.antenna.monitor",
    "productName": "Antenna Monitor",
    "copyright": "Antenna Monitor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "error.html"
    ],
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ]
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}